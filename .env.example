# ─── Supabase ────────────────────────────────────────────────────────────────
# From your Supabase project: Settings → API.
# These two are safe in the browser (the anon key is publishable and protected by RLS).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key

# Server-only. NEVER commit a real value and never expose it to the browser.
# Set this in Netlify (Site settings → Environment variables), not in the repo.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public base URL of the deployment (used for absolute links / QR codes).
# Locally this is http://localhost:3000; in prod it's your Netlify or custom domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
